@page "/servers/{Id:int}/history"
@rendermode InteractiveServer

@using GameOpsMini.Dashboard.Services
@using GameOpsMini.Shared.Models

@inject GameOpsApiClient ApiClient

<PageTitle>Server History</PageTitle>

<div class="mb-3">
    <a class="btn btn-outline-secondary" href="/servers">
        서버 목록으로
    </a>
</div>

@if (isLoading)
{
    <p>Loading server history...</p>
}
else if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger" role="alert">
        @errorMessage
    </div>
}
else if (server is null)
{
    <div class="alert alert-warning" role="alert">
        서버를 찾을 수 없습니다.
    </div>
}
else
{
    <h1>@server.Name</h1>

    <div class="mb-4">
        <div>
            <strong>주소:</strong>
            @server.Host:@server.Port
        </div>

        <div>
            <strong>현재 상태:</strong>
            <span class="@GetStateBadgeClass(server.State)">
                @GetStateText(server.State)
            </span>
        </div>

        <div>
            <strong>마지막 검사:</strong>
            @FormatDateTime(server.LastCheckedAt)
        </div>

        <div>
            <strong>실패 횟수:</strong>
            @server.FailureCount
        </div>

        <div>
            <strong>메시지:</strong>
            @server.Message
        </div>
    </div>

    <div class="d-flex align-items-center gap-2 mb-3">
        <h2 class="mb-0">상태 변경 이력</h2>

        <button class="btn btn-sm btn-primary" @onclick="LoadDataAsync" disabled="@isLoading">
            @(isLoading ? "갱신 중..." : "새로고침")
        </button>
    </div>

    @if (histories.Count == 0)
    {
        <div class="alert alert-secondary" role="alert">
            저장된 상태 변경 이력이 없습니다.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>상태</th>
                        <th>확인 시간</th>
                        <th>실패 횟수</th>
                        <th>메시지</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var history in histories)
                    {
                        <tr>
                            <td>@history.Id</td>

                            <td>
                                <span class="@GetStateBadgeClass(history.State)">
                                    @GetStateText(history.State)
                                </span>
                            </td>

                            <td>@FormatDateTime(history.CheckedAt)</td>

                            <td>@history.FailureCount</td>

                            <td>@history.Message</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}

@code {
    [Parameter]
    public int Id { get; set; }

    private ServerStatus? server;
    private readonly List<ServerStatusHistoryDto> histories = [];

    private bool isLoading;
    private string? errorMessage;

    protected override async Task OnParametersSetAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        if (isLoading)
        {
            return;
        }

        isLoading = true;
        errorMessage = null;

        try
        {
            var serverResult = await ApiClient.GetServerAsync(Id);

            if (serverResult is null)
            {
                server = null;
                histories.Clear();
                return;
            }

            server = serverResult;

            var historyResult =
                await ApiClient.GetServerHistoryAsync(Id);

            histories.Clear();
            histories.AddRange(historyResult);
        }
        catch (OperationCanceledException)
        {
            // 페이지 이동 또는 요청 취소 시 오류로 표시하지 않는다.
        }
        catch (GameOpsApiException ex)
        {
            errorMessage = ex.Message;
        }
        catch (Exception)
        {
            errorMessage =
                "서버 이력을 불러오는 중 예상하지 못한 오류가 발생했습니다.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private static string GetStateText(ServerState state)
    {
        return state switch
        {
            ServerState.Up => "UP",
            ServerState.Down => "DOWN",
            _ => "UNKNOWN"
        };
    }

    private static string GetStateBadgeClass(ServerState state)
    {
        return state switch
        {
            ServerState.Up => "badge text-bg-success",
            ServerState.Down => "badge text-bg-danger",
            _ => "badge text-bg-secondary"
        };
    }

    private static string FormatDateTime(DateTime dateTime)
    {
        if (dateTime == default || dateTime == DateTime.MinValue)
        {
            return "-";
        }

        return dateTime
            .ToLocalTime()
            .ToString("yyyy-MM-dd HH:mm:ss");
    }
}